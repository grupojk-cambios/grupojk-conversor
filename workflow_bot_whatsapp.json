                  {
                      "parameters":  {
                                         "jsCode":  "const csv = $node[\"Consultar Tasas\"].json.data;\nconst lineas = csv.split(\u0027\\r\\n\u0027);\nconst resultados = [];\n\nfor (let i = 1; i \u003c lineas.length; i++) {\n  const col = lineas[i].split(\u0027,\u0027);\n  if (col.length \u003c 5) continue;\n\n  const tE = parseFloat(col[1]) || 0;\n  const mE = parseFloat(col[2]) || 0;\n  const tR = parseFloat(col[3]) || 0;\n  const mR = parseFloat(col[4]) || 0;\n\n  resultados.push({\n    Pais: col[0],\n    \"Envio\": (tE * (1 - mE / 100)).toFixed(2),\n    \"Recibo\": (tR * (1 + mR / 100)).toFixed(2)\n  });\n}\n\nreturn { lista: resultados }; \n"
                                     },
